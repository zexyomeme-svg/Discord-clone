# Flask/Render sets PORT automatically in production.
PORT=8000

# Optional: override the upstream Discord API base URL.
DISCORD_API_BASE=https://discord.com/api/v10

# Optional: comma-separated origins if you want to lock down the proxy CORS policy.
CORS_ORIGINS=*

# Optional: upstream request timeout in seconds.
PROXY_TIMEOUT=30

# Optional: set to 0 to stop run.py from automatically installing/building the frontend.
AUTO_BUILD_FRONTEND=1

# Optional: Node version used by nodeenv if system Node/npm is unavailable.
NODE_VERSION=20.20.2

# Optional: where nodeenv installs a local Node runtime.
NODEENV_DIR=.nodeenv

# Optional: explicit npm executable path. Leave blank normally.
NPM_BINARY=

# Discord OAuth2 login. Create these in https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_OAUTH_SCOPES=identify email guilds
# Public URL of your deployed app, for example https://your-app.onrender.com
PUBLIC_BASE_URL=
# Optional explicit callback URL. If unset, defaults to PUBLIC_BASE_URL/auth/discord/callback
DISCORD_REDIRECT_URI=
OAUTH_STATE_MAX_AGE=600
